<title>Welcome Web Aan</title>
<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #f0fff4;
}

/* HEADER */
header {
    background: linear-gradient(90deg, #2e8b57, #66bb6a);
    color: white;
    padding: 15px;
    text-align: center;
}

/* NAV */
nav {
    background-color: #3cb371;
    padding: 10px;
    text-align: center;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
    font-weight: bold;
}

nav a:hover {
    color: #ffeb3b;
}

/* CONTENT */
.container {
    padding: 20px;
    background-color: white;
    margin: 20px;
    border-radius: 8px;
}

/* SECTION */
section { display: none; }
section:target { display: block; }

/* HOME default tampil */
#home { display: block; }

/* Saat profil/kontak dibuka, home disembunyikan */
section:target ~ #home { display: none; }

/* FOTO PROFIL */
.profile-img {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 10px;
}

/* FOOTER */
footer {
    background: linear-gradient(90deg, #2e8b57, #66bb6a);
    color: white;
    text-align: center;
    padding: 10px;
}
</style>
</head>
