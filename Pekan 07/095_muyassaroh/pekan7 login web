<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Website Sederhana - Belajar HTML Dasar</title>
    <style>
        /* Reset Dasar */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: red;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Header */
        header {
            background-color: #2c3e50;
            color: white;
            text-align: center;
            padding: 40px 20px;
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        /* Navigasi */
        nav {
            background-color: #34495e;
            display: flex;
            justify-content: center;
            padding: 15px 0;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 20px;
            font-weight: bold;
            transition: color 0.3s;
            cursor: pointer;
        }

        nav a:hover {
            color: #3498db;
        }

        /* Konten Utama */
        main {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: 40px 20px;
        }

        .container {
            background-color: yellow;
            width: 100%;
            max-width: 800px;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        h2 {
            font-size: 2rem;
            margin-bottom: 20px;
        }

        .deskripsi {
            line-height: 1.6;
            margin-bottom: 25px;
            color: #333;
        }

        h3 {
            margin-bottom: 15px;
        }

        ul {
            margin-left: 20px;
            line-height: 1.8;
        }

        /* Footer */
        footer {
            background-color: #2c3e50;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: auto;
        }

        /* Modal Login Sederhana */
        #loginOverlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: blue;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .login-box {
            background: orange;
            padding: 30px;
            border-radius: 8px;
            text-align: center;
            width: 300px;
        }

        .login-box input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .login-box button {
            background: magenta;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 4px;
            width: 100%;
        }

        .login-box button:hover {
            background: blue;
        }
    </style>
</head>
<body>

    <header>
        <h1>Website Sederhana</h1>
        <p>Belajar HTML dasar</p>
    </header>

    <nav>
        <a onclick="showLogin('Home')">Home</a>
        <a onclick="showLogin('Profil')">Profil</a>
        <a onclick="showLogin('Kontak')">Kontak</a>
    </nav>

    <main>
        <div class="container">
            <h2>Selamat Datang</h2>
            <p class="deskripsi">
                Ini adalah contoh tampilan web sederhana menggunakan HTML dan CSS. 
                Anda bisa mengembangkan desain ini menjadi website yang lebih lengkap.
            </p>

            <h3>Materi Dasar HTML</h3>
            <ul>
                <li>Struktur HTML</li>
                <li>Heading dan Paragraf</li>
                <li>Link</li>
                <li>List</li>
            </ul>
        </div>
    </main>

    <div id="loginOverlay">
        <div class="login-box">
            <h2 id="loginTitle">Login</h2>
            <p id="loginMessage" style="font-size: 0.9rem; margin-bottom: 10px;"></p>
            <input type="text" placeholder="Username" id="user">
            <input type="password" placeholder="Password" id="pass">
            <button onclick="handleLogin()">Masuk</button>
            <button onclick="closeLogin()" style="background: #e74c3c; margin-top: 5px;">Batal</button>
        </div>
    </div>

    <footer>
        <p>&copy; 2026 - Belajar Pemrograman Web</p>
    </footer>

    <script>
        const overlay = document.getElementById('loginOverlay');
        const loginTitle = document.getElementById('loginTitle');
        const loginMessage = document.getElementById('loginMessage');

        // Fungsi untuk menampilkan form login
        function showLogin(menu) {
            overlay.style.display = 'flex';
            loginTitle.innerText = 'Login ke ' + menu;
            loginMessage.innerText = 'Silahkan login untuk mengakses halaman ' + menu;
        }

        // Fungsi untuk menutup form login
        function closeLogin() {
            overlay.style.display = 'none';
        }

        // Fungsi simulasi login
        function handleLogin() {
            const user = document.getElementById('user').value;
            const pass = document.getElementById('pass').value;

            if(user !== "" && pass !== "") {
                alert("Selamat datang, " + user + "! Anda berhasil masuk.");
                closeLogin();
            } else {
                alert("Mohon isi username dan password.");
            }
        }

        // Menutup modal jika klik di luar kotak login
        window.onclick = function(event) {
            if (event.target == overlay) {
                closeLogin();
            }
        }
    </script>

</body>
</html>
